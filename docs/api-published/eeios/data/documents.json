lass</td>\n<td style=\"text-align: right;\">5</td>\n<td>—</td>\n</tr>\n<tr>\n<td><a href=\"pages/invoicecell/\">InvoiceCell</a></td>\n<td>Page / Window</td>\n<td style=\"text-align: right;\">0</td>\n<td>—</td>\n</tr>\n<tr>\n<td><a href=\"pages/invoicescreen/\">InvoiceScreen</a></td>\n<td>Page / Window</td>\n<td style=\"text-align: right;\">0</td>\n<td>—</td>\n</tr>\n<tr>\n<td><a href=\"classes/saleschart/\">SalesChart</a></td>\n<td>Class</td>\n<td style=\"text-align: right;\">2</td>\n<td>mobileChart</td>\n</tr>\n<tr>\n<td><a href=\"pages/salesscreen/\">SalesScreen</a></td>\n<td>Page / Window</td>\n<td style=\"text-align: right;\">0</td>\n<td>—</td>\n</tr>\n<tr>\n<td><a href=\"classes/section/\">Section</a></td>\n<td>Class</td>\n<td style=\"text-align: right;\">3</td>\n<td>—</td>\n</tr>\n<tr>\n<td><a href=\"pages/yearscreen/\">YearScreen</a></td>\n<td>Page / Window</td>\n<td style=\"text-align: right;\">0</td>\n<td>—</td>\n</tr>\n<tr>\n<td><a href=\"pages/ipadlayout/\">iPadLayout</a></td>\n<td>Page / Window</td>\n<td style=\"text-align: right;\">0</td>\n<td>—</td>\n</tr>\n<tr>\n<td><a href=\"pages/iphonelayout/\">iPhoneLayout</a></td>\n<td>Page / Window</td>\n<td style=\"text-align: right;\">0</td>\n<td>—</td>\n</tr>\n</tbody>\n</table>\n<blockquote>\n<p>Entity types that exist in the official Xojo API link to <a href=\"https://documentation.xojo.com/index.html\">the Xojo documentation</a>.</p>\n</blockquote>"},{"location":"classes/app/","title":"App","text":"<p><code>Class</code> <code>Protected</code></p>\n<p><strong>Inherits:</strong> <a href=\"https://documentation.xojo.com/api/mobile/mobileapplication.html\">MobileApplication</a>  </p>"},{"location":"classes/customer/","title":"Customer","text":"<p><code>Class</code> <code>Protected</code></p>"},{"location":"classes/customer/#methods","title":"Methods","text":""},{"location":"classes/customer/#save","title":"Save","text":"<p><code>Public</code></p>\n<pre><code class=\"language-xojo\">Sub Save()\n  Var sql As String\n  sql = \"UPDATE Customers SET FirstName = ?1, LastName = ?2, \" + _\n  \"Address = ?3, City = ?4, State = ?5, Zip = ?6, Phone = ?7, \" + _\n  \"Email = ?8, Taxable = ?9 WHERE ID = ?10\"\n\n  // Pass in values after sql instead of doing string replacement\n  App.EEDB.ExecuteSQL(sql, FirstName, LastName, Address, City, State, _\n  Zip, Phone, Email, Taxable, ID)\n\nEnd Sub</code></pre>"},{"location":"classes/customer/#properties","title":"Properties","text":""},{"location":"classes/customer/#address","title":"Address","text":"<p><code>Public</code></p>\n<pre><code>Address As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"classes/customer/#city","title":"City","text":"<p><code>Public</code></p>\n<pre><code>City As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"classes/customer/#email","title":"Email","text":"<p><code>Public</code></p>\n<pre><code>Email As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"classes/customer/#firstname","title":"FirstName","text":"<p><code>Public</code></p>\n<pre><code>FirstName As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"classes/customer/#id","title":"ID","text":"<p><code>Public</code></p>\n<pre><code>ID As <a href=\"https://documentation.xojo.com/api/data_types/integer.html\">Integer</a></code></pre>"},{"location":"classes/customer/#lastname","title":"LastName","text":"<p><code>Public</code></p>\n<pre><code>LastName As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"classes/customer/#phone","title":"Phone","text":"<p><code>Public</code></p>\n<pre><code>Phone As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"classes/customer/#photo","title":"Photo","text":"<p><code>Public</code></p>\n<pre><code>Photo As <a href=\"https://documentation.xojo.com/api/graphics/picture.html\">Picture</a></code></pre>"},{"location":"classes/customer/#state","title":"State","text":"<p><code>Public</code></p>\n<pre><code>State As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"classes/customer/#taxable","title":"Taxable","text":"<p><code>Public</code></p>\n<pre><code>Taxable As <a href=\"https://documentation.xojo.com/api/data_types/boolean.html\">Boolean</a></code></pre>"},{"location":"classes/customer/#zip","title":"Zip","text":"<p><code>Public</code></p>\n<pre><code>Zip As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"classes/customer/#computed-properties","title":"Computed Properties","text":""},{"location":"classes/customer/#fulladdress","title":"FullAddress","text":"<p><code>Public</code></p>\n<pre><code>FullAddress As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a> (read-only)</code></pre>\n\n<details class=\"source\"><summary>Source</summary>\n\n<pre><code class=\"language-xojo\">Get\n  Var addr As String = Address + EndOfLine.iOS + _\n  City + \", \" + State + \" \" + Zip\n\n  Return addr\n\nEnd Get</code></pre>\n\n</details>"},{"location":"classes/customer/#fullname","title":"FullName","text":"<p><code>Public</code></p>\n<pre><code>FullName As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a> (read-only)</code></pre>\n\n<details class=\"source\"><summary>Source</summary>\n\n<pre><code class=\"language-xojo\">Get\n  Return FirstName + \" \" + LastName\nEnd Get</code></pre>\n\n</details>"},{"location":"classes/customer/#shortaddress","title":"ShortAddress","text":"<p><code>Public</code></p>\n<pre><code>ShortAddress As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a> (read-only)</code></pre>\n\n<details class=\"source\"><summary>Source</summary>\n\n<pre><code class=\"language-xojo\">Get\n  Return City + \", \" + State + \" \" + Zip\nEnd Get</code></pre>\n\n</details>"},{"location":"classes/invoice/","title":"Invoice","text":"<p><code>Class</code> <code>Protected</code></p>"},{"location":"classes/invoice/#methods","title":"Methods","text":""},{"location":"classes/invoice/#getyears","title":"GetYears","text":"<p><code>Public</code></p>\n<p>For the specified year, group the invoices by month and then sum the amounts for the month</p>\n<pre><code class=\"language-xojo\">Shared Function GetYears() As String()\n  // For the specified year, group the invoices by month and then sum the amounts for the month\n  Var sql As String = \"SELECT DISTINCT SubStr(InvoiceDate, 1, 4) FROM Invoices ORDER BY InvoiceDate DESC\"\n\n  Try\n    Var rs As RowSet = App.EEDB.SelectSQL(sql)\n\n    Var years() As String\n\n    If rs &lt;&gt; Nil Then\n      While Not rs.AfterLastRow\n        // Put the year into the array\n        years.Add(rs.ColumnAt(0).StringValue)\n        rs.MoveToNextRow\n      Wend\n      rs.Close\n    End If\n\n    Return years\n  Catch e As DatabaseException\n    Return Nil\n  End Try\nEnd Function</code></pre>"},{"location":"classes/invoice/#properties","title":"Properties","text":""},{"location":"classes/invoice/#customer","title":"Customer","text":"<p><code>Public</code></p>\n<pre><code>Customer As <a href=\"../customer/\">Customer</a></code></pre>"},{"location":"classes/invoice/#invoiceamount","title":"InvoiceAmount","text":"<p><code>Public</code></p>\n<pre><code>InvoiceAmount As <a href=\"https://documentation.xojo.com/api/data_types/currency.html\">Currency</a></code></pre>"},{"location":"classes/invoice/#invoicedate","title":"InvoiceDate","text":"<p><code>Public</code></p>\n<pre><code>InvoiceDate As <a href=\"https://documentation.xojo.com/api/data_types/datetime.html\">DateTime</a></code></pre>"},{"location":"classes/invoice/#invoicenumber","title":"InvoiceNumber","text":"<p><code>Public</code></p>\n<pre><code>InvoiceNumber As <a href=\"https://documentation.xojo.com/api/data_types/integer.html\">Integer</a></code></pre>"},{"location":"classes/saleschart/","title":"SalesChart","text":"<p><code>Class</code> <code>Protected</code></p>\n<p><strong>Inherits:</strong> <a href=\"https://documentation.xojo.com/api/user_interface/mobile/mobilechart.html\">mobileChart</a>  </p>"},{"location":"classes/saleschart/#methods","title":"Methods","text":""},{"location":"classes/saleschart/#getmonthlyinvoicetotalsbyyear","title":"GetMonthlyInvoiceTotalsByYear","text":"<p><code>Protected, Shared</code></p>\n<p>For the specified year, group the invoices by month and then sum the amounts for the month</p>\n<pre><code class=\"language-xojo\">Private Function GetMonthlyInvoiceTotalsByYear(year As String) As Double()\n  // For the specified year, group the invoices by month and then sum the amounts for the month\n  Var sql As String = \"SELECT SubStr(InvoiceDate, 6, 2), Sum(InvoiceAmount) FROM invoices WHERE substr(invoicedate, 1, 4)  = ? GROUP BY SubStr(InvoiceDate, 6, 2) ORDER BY SubStr(InvoiceDate, 6, 2)\"\n\n  Try\n    Var rs As RowSet = App.EEDB.SelectSQL(sql, year)\n\n    Var amounts(11) As Double\n\n    If rs &lt;&gt; Nil Then\n      While Not rs.AfterLastRow\n        // Put the amount for the month into the array\n        Var month As Integer\n        month = Integer.FromString(rs.ColumnAt(0).StringValue)\n        amounts(month - 1) = rs.ColumnAt(1).CurrencyValue\n\n        rs.MoveToNextRow\n      Wend\n      rs.Close\n    End If\n\n    Return amounts\n  Catch e As DatabaseException\n    Return Nil\n  End Try\nEnd Function</code></pre>"},{"location":"classes/saleschart/#loaddata","title":"LoadData","text":"<p><code>Public</code></p>\n<pre><code class=\"language-xojo\">Sub LoadData(Year as String)\n  Me.RemoveAllDatasets\n\n  Var amounts() As Double\n  amounts = GetMonthlyInvoiceTotalsByYear(year)\n\n  Var ds As New ChartLinearDataset(\"Sales\", Color.Blue, True, amounts)\n  me.AddDataset ds\nEnd Sub</code></pre>"},{"location":"classes/section/","title":"Section","text":"<p><code>Class</code> <code>Protected</code></p>"},{"location":"classes/section/#properties","title":"Properties","text":""},{"location":"classes/section/#count","title":"Count","text":"<p><code>Public</code></p>\n<pre><code>Count As <a href=\"https://documentation.xojo.com/api/data_types/integer.html\">Integer</a></code></pre>"},{"location":"classes/section/#_1","title":"Section","text":"<p><code>Public</code></p>\n<pre><code>As</code></pre>"},{"location":"classes/section/#title","title":"Title","text":"<p><code>Public</code></p>\n<pre><code>Title As <a href=\"https://documentation.xojo.com/api/data_types/string.html\">String</a></code></pre>"},{"location":"pages/aboutscreen/","title":"AboutScreen","text":"<p><code>Page / Window</code> <code>Public</code></p>"},{"location":"pages/aboutscreen/#controls","title":"Controls","text":"<ul>\n<li><a href=\"https://documentation.xojo.com/api/user_interface/mobile/mobilescreen.html\">MobileScreen</a> <strong>AboutScreen</strong></li>\n<li><a href=\"https://documentation.xojo.com/api/user_interface/mobile/mobilebutton.html\">MobileButton</a> <strong>StartButton — \"Tap to Start\"</strong></li>\n<li><a href=\"https://documentation.xojo.com/api/user_interface/mobile/mobileimageviewer.html\">MobileImageViewer</a> <strong>LogoView</strong></li>\n<li><a href=\"https://documentation.xojo.com/api/user_interface/mobile/mobilelabel.html\">MobileLabel</a> <strong>AboutLabel</strong></li>\n</ul>"},{"location":"pages/customerdetailscreen/","title":"CustomerDetailScreen","text":"<p><code>Page / Window</code> <code>Public</code></p>"},{"location":"pages/customerdetailscreen/#controls","title":"Controls","text":"<ul>\n<li><a href=\"https://documentation.xojo.com/api/user_interface/mobile/mobilescreen.html\">MobileScreen</a> <strong>CustomerDetailScreen</strong></li>\n<li><a href=\"https://documentation.xojo.com/api/user_interface/m